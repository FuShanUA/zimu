# Global pause event for pausing batch scheduling
global_pause = threading.Event()
global_pause.set()
global_abort = False
global_ui_log = "[grey50]等候指令中...[/grey50]"

active_processes = {}  # title -> pid
paused_videos = set()  # set of titles globally paused
ui_scroll_offset = 0   # Vertical scroll offset for the dashboard

video_ids = {}         # title -> char ID
next_id_idx = 0
ID_CHARS = "1234567890abcdefghijlmnoqstuvwxyz"

registry = [] # Global list of projects dicts
registry_lock = threading.RLock()

import autosub

def get_video_id(uid):
    global next_id_idx
    with registry_lock:
        if uid not in video_ids:
            video_ids[uid] = ID_CHARS[next_id_idx % len(ID_CHARS)]
            next_id_idx += 1
        return video_ids[uid]

def suspend_process_tree(pid):
    try:
        parent = psutil.Process(pid)
        for child in parent.children(recursive=True): child.suspend()
        parent.suspend()
    except Exception: pass

def resume_process_tree(pid):
    try:
        parent = psutil.Process(pid)
        for child in parent.children(recursive=True): child.resume()
        parent.resume()
    except Exception: pass

# Setup path and import autosub
CURRENT_DIR = os.path.dirname(os.path.abspath(__file__))
if CURRENT_DIR not in sys.path:
    sys.path.append(CURRENT_DIR)

try:
    import autosub
    from autosub import get_video_duration, VDOWN_CMD, TRANSCRIBER_CMD, SMART_TRANSLATE_CMD, SUBTRANSLATOR_CMD, SRT2ASS_CMD, BURNSUB_CMD
except Exception as e:
    print(f"Failed to import autosub: {e}")
    sys.exit(1)

def sanitize_filename(name):
    clean = re.sub(r'[\\/*?:"<>|]', '_', name)
    clean = clean.strip().strip('.')
    clean = re.sub(r'\s+', ' ', clean).strip()
    return clean[:100]

def log_event(workdir, level, msg):
    log_path = os.path.join(workdir, "batch_workflow.log")
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(log_path, "a", encoding="utf-8") as f:
        f.write(f"[{timestamp}] [{level}] {msg}\n")

# --- Balanced Weights ---
STAGE_WEIGHTS = {
    "dl": 0.10, # Download
    "tr": 0.40, # Transcribe
    "tl": 0.15, # Translate
    "mg": 0.05, # Merge/SRT/ASS
    "bn": 0.30  # Burn
}

def calculate_total_progress(uid):
    total = 0.0
    with registry_lock:
        for stage, weight in STAGE_WEIGHTS.items():
            prog_map = {
                "dl": tasks_dl, "tr": tasks_tr, "tl": tasks_tl, "mg": tasks_mg, "bn": tasks_bn
            }
            prog_inst = {
                "dl": prog_dl, "tr": prog_tr, "tl": prog_tl, "mg": prog_mg, "bn": prog_bn
            }
            tid = prog_map[stage].get(uid)
            if tid is not None:
                task = prog_inst[stage]._tasks.get(tid)
                if task:
                    total += (task.completed / 100.0) * (weight * 100.0)
    return min(total, 100.0)

# --- Dynamic UI Architecture ---
class StatefulBarColumn(BarColumn):
    def render(self, task):
        # Override styles dynamically depending on task flags
        state = task.fields.get('ui_state', 'unstarted')
        if state == 'skipped':
            self.complete_style = "grey50"
            self.finished_style = "grey50"
        elif state == 'failed':
            self.complete_style = "bright_red"
            self.finished_style = "bright_red"
        elif state == 'completed':
            self.complete_style = "green"
            self.finished_style = "green"
        elif state == 'active':
            self.complete_style = "bright_blue"
            self.finished_style = "green"
        else: # unstarted
            self.complete_style = "grey15"
            self.finished_style = "grey15"
        return super().render(task)

def create_progress():
    # Use auto_refresh=False as we use Live for manual rendering. 
    return Progress(
        TextColumn("{task.description}", justify="left"),
        StatefulBarColumn(bar_width=40, style="grey15", pulse_style="grey15"),
        TextColumn("[{task.fields[pct_color]}]{task.percentage:>5.2f}%", justify="right"),
        TextColumn("用时:"), TimeElapsedColumn(),
        TextColumn("剩余:"), TimeRemainingColumn(),
        auto_refresh=False
    )

prog_dl = create_progress()
prog_tr = create_progress()
prog_tl = create_progress()
prog_mg = create_progress()
prog_bn = create_progress()

stage_visibility = {"dl": False, "tr": False, "tl": False, "mg": False, "bn": False}
stage_locks = {k: threading.Lock() for k in stage_visibility}
tasks_dl = {}; tasks_tr = {}; tasks_tl = {}; tasks_mg = {}; tasks_bn = {}

def initialize_all_tasks():
    stages = [
        ("dl", prog_dl, tasks_dl, "下载"),
        ("tr", prog_tr, tasks_tr, "转录"),
        ("tl", prog_tl, tasks_tl, "翻译"),
        ("mg", prog_mg, tasks_mg, "合并"),
        ("bn", prog_bn, tasks_bn, "烧录")
    ]
    with registry_lock:
        for proj in registry:
            uid = proj['uid']
            title = proj['title']
            vid = get_video_id(uid)
            for stage_key, prog_instance, task_map, stage_prefix in stages:
                if stage_key == "dl" and not proj.get("is_url") and not proj.get("is_local"): continue
                desc = f"[grey50][ID:{vid}] {stage_prefix}: {title}[/grey50]"
                tid = prog_instance.add_task(desc, total=100.0, start=False, vid=vid, title=title, ui_state="unstarted", pct_color="grey50")
                task_map[uid] = tid
        for stage_key, _, _, _ in stages:
            stage_visibility[stage_key] = True

class DynamicPipelineGroup:
    def __rich__(self):
        try:
            from rich.table import Table
            from rich.progress import BarColumn, TimeRemainingColumn
            from rich import box
            from rich.console import Group

            table = Table(title="[bold yellow]AutoSub 批处理任务面板 (Consolidated Dashboard)[/bold yellow]", 
                          expand=True, box=box.SIMPLE_HEAVY, header_style="bold cyan")
            
            table.add_column("VID", width=4, justify="center")
            table.add_column("任务标题 / 状态", width=40, no_wrap=True)
            table.add_column("下载 (DL)", width=15)
            table.add_column("转录 (TR)", width=14)
            table.add_column("翻译 (TL)", width=14)
            table.add_column("合并 (MG)", width=14)
            table.add_column("烧录 (BN)", width=14)
            table.add_column("ETA", width=10, justify="right")

            # Source of truth: all unique UIDs encountered
            all_uids = list(tasks_dl.keys())
            if not all_uids:
                # Fallback to registry if tasks not initialized yet
                with registry_lock:
                    all_uids = [proj['uid'] for proj in registry]
            
            # Sort by assigned ID to keep order stable
            sorted_uids = sorted(all_uids, key=lambda x: get_video_id(x))

            eta_renderer = TimeRemainingColumn()

            all_uids = sorted(tasks_dl.keys(), key=lambda x: get_video_id(x))
            
            # Simple scrolling logic
            global ui_scroll_offset
            items_per_page = 15
            visible_uids = all_uids[ui_scroll_offset : ui_scroll_offset + items_per_page]

            for uid in visible_uids:
                row_items = []
                
                # 1. VID
                vid = get_video_id(uid)
                row_items.append(f"[grey50]{vid}[/grey50]")
                
                # 2. Title & Global Status
                current_title = "Unknown"
                current_stage = "Wait"
                
                all_stages = [
                    ("dl", prog_dl, tasks_dl),
                    ("tr", prog_tr, tasks_tr),
                    ("tl", prog_tl, tasks_tl),
                    ("mg", prog_mg, tasks_mg),
                    ("bn", prog_bn, tasks_bn)
                ]
                
                stage_bars = []
                active_eta = None
                
                for code, prog, mapping in all_stages:
                    tid = mapping.get(uid)
                    if tid is not None:
                        task = prog._tasks.get(tid)
                        if task:
                            current_title = task.fields.get('title', uid)
                            ui_state = task.fields.get('ui_state', 'unstarted')
                            
                            # Render Percent & Color
                            pct_color = task.fields.get('pct_color', 'grey50')
                            # If completed, use green
                            if ui_state == 'completed': pct_color = "green"
                            elif ui_state == 'active': pct_color = "bright_blue"
                            
                            bar_text = f"[{pct_color}]{task.percentage:>5.1f}%[/]"
                            stage_bars.append(bar_text)
                            
                            if ui_state == 'active':
                                active_stage = code.upper()
                                active_task = task
                            elif ui_state == 'failed':
                                active_stage = f"[bold red]{code.upper()}!任务失败[/]"
                            elif ui_state == 'completed' and active_stage == "Wait":
                                active_stage = "DONE"

                # Coloring based on progress
                if total_pct >= 99.9: bar_color = "green"
                elif "失败" in active_stage: bar_color = "red"
                elif active_stage == "Wait": bar_color = "grey30"
                else: bar_color = "bright_blue"

                # Construct Row
                row_id = f"[{bar_color}]{vid}[/]"
                
                status_line = f"[bold white]{current_title}[/]"
                if active_stage != "Wait" and active_stage != "DONE":
                    status_line += f"\n[dim cyan]当前阶段: {active_stage}[/]"
                elif active_stage == "DONE":
                    status_line += f"\n[dim green]处理完成[/]"
                
                # Progress Bar
                bar_width = 30
                filled = int((total_pct / 100.0) * bar_width)
                bar_str = f"[{bar_color}]" + "█" * filled + "[/][grey15]" + "░" * (bar_width - filled) + "[/]"
                
                # Time stats
                from rich.progress import TimeElapsedColumn, TimeRemainingColumn
                elapsed = TimeElapsedColumn().render(active_task) if active_task else "0:00:00"
                eta = TimeRemainingColumn().render(active_task) if active_task else "--:--:--"
                if active_stage == "DONE":
                    eta = "[green]OK[/]"
                elif active_stage == "Wait":
                    eta = "[grey30]--[/]"

                table.add_row(
                    row_id,
                    status_line,
                    bar_str,
                    f"[{bar_color}]{total_pct:>5.1f}%[/]",
                    f"[grey50]{elapsed}[/]",
                    f"[bold yellow]{eta}[/]"
                )

            # Footer / Control Panel
            cmd_panel = Panel(
                Text.from_markup(
                    f" [bold cyan]P[/] 暂停/接续全队列 | [bold cyan]ID[/] 暂停特定视频 (如按 '1') | [bold cyan]R+ID[/] 重启失败任务 | [bold cyan]Q[/] 优雅退出\n" +
                    f" {global_ui_log}",
                ),
                title="[bold yellow]控制台命令区[/bold yellow]",
                border_style="bright_blue",
                padding=(0, 1)
            )
            
            return Group(table, cmd_panel)
        except Exception as e:
            import traceback
            return Text(f"❌ UI Error: {e}\n{traceback.format_exc()}", style="bold red")
# -------------------------------

def run_cmd_with_progress(cmd, progress, task_id, step_name, workdir, title):
    log_event(workdir, "START", f"Starting {step_name}: {' '.join(cmd)}")
    try:
        process = subprocess.Popen(
            cmd, 
            stdout=subprocess.PIPE, 
            stderr=subprocess.STDOUT, 
            text=True, 
            encoding='utf-8', 
            errors='replace', 
            creationflags=subprocess.CREATE_NO_WINDOW if sys.platform == "win32" else 0
        )
        active_processes[title] = process.pid
        if title in paused_videos: suspend_process_tree(process.pid)
        
        last_percent = 0.0
        for line in process.stdout:
            msg = line.strip()
            percent = None
            if "Progress:" in msg:
                m = re.search(r'Progress:\s*([\d\.]+)%', msg)
                if m: percent = float(m.group(1))
            elif "[download]" in msg and "%" in msg:
                m = re.search(r'\[download\]\s*([\d\.]+)%', msg)
                if m: percent = float(m.group(1))
            
            if percent is not None and percent != last_percent:
                progress.update(task_id, completed=percent)
                last_percent = percent
            
            if "ERROR:" in msg or "Failed" in msg:
                log_event(workdir, "ERROR_TRACE", msg)
                progress.update(task_id, description=f"[bold red]❌ {msg[:40]}...[/bold red]")
                
        process.wait()
        if process.returncode == 0:
            log_event(workdir, "SUCCESS", f"Completed {step_name} at 100.00%")
            progress.update(task_id, completed=100.0)
            if title in active_processes: del active_processes[title]
            return True
        else:
            log_event(workdir, "FAIL", f"{step_name} failed with exit code {process.returncode}")
            if title in active_processes: del active_processes[title]
            return False
    except Exception as e:
        log_event(workdir, "ERROR", f"{step_name} critical error: {e}")
        if title in active_processes: del active_processes[title]
        return False

def downloader_worker(download_queue, transcribe_queue, args, output_dir):
    while not download_queue.empty():
        if global_abort: break
        global_pause.wait()
        try:
            item = download_queue.get(timeout=1)
            url = item['url']
            initial_title = item['title']
            
            vid = get_video_id(item['uid'])
            tid = tasks_dl.get(item['uid'])

            if url.startswith("local://"):
                video_path = url[8:]
                safe_title = initial_title
                workdir = os.path.dirname(video_path)
                prog_dl.start_task(tid)
                prog_dl.update(tid, description=f"[grey50][ID:{vid}] 下载: {safe_title} (本地)[/grey50]", ui_state="skipped", pct_color="grey50", completed=100.0)
                transcribe_queue.put({"uid": item['uid'], "video_path": video_path, "workdir": workdir, "title": safe_title})
                download_queue.task_done()
                continue
            
            # Resolve real title
            title = initial_title
            safe_title = initial_title
            if initial_title.startswith("URL_") and initial_title[4:].isdigit():
                real_title = autosub.get_video_title(url, args.cookies)
                if real_title: safe_title = sanitize_filename(real_title)
                else: safe_title = initial_title
            
            # Update mappings if title changed (Sync to ALL stages)
            if safe_title != initial_title:
                with registry_lock:
                    for p in registry:
                        if p['uid'] == item['uid']: p['title'] = safe_title
                
                # Update visual labels for ALL stages immediately
                for stage_prog, stage_tasks, stage_prefix in [
                    (prog_dl, tasks_dl, "下载"), (prog_tr, tasks_tr, "转录"), 
                    (prog_tl, tasks_tl, "翻译"), (prog_mg, tasks_mg, "合并"), (prog_bn, tasks_bn, "烧录")
                ]:
                    st_tid = stage_tasks.get(item['uid'])
                    if st_tid is not None:
                        is_current = (stage_prog == prog_dl)
                        style = "blue" if is_current else "grey50"
                        prefix = stage_prefix
                        stage_prog.update(st_tid, description=f"[{style}][ID:{vid}] {prefix}: {safe_title}[/{style}]")
                
                item['title'] = safe_title

            workdir = os.path.join(output_dir, safe_title)
            os.makedirs(workdir, exist_ok=True)
            item["workdir"] = workdir
            
            # Downloader skip logic
            vids = []
            if os.path.exists(workdir):
                vids = [f for f in glob.glob(os.path.join(workdir, "*")) if os.path.splitext(f)[1].lower() in ['.mp4', '.mkv', '.webm', '.ts', '.mov', '.avi'] and not f.endswith('.part') and '_hardsub' not in f.lower()]
            
            if vids:
                video_path = max(vids, key=os.path.getmtime)
                log_event(workdir, "SKIP", f"Video exists: {os.path.basename(video_path)}")
                prog_dl.start_task(tid)
                prog_dl.update(tid, description=f"[grey50][ID:{vid}] 下载: {safe_title} (跳过)[/grey50]", ui_state="skipped", pct_color="grey50", completed=100.0)
                transcribe_queue.put({"uid": item['uid'], "video_path": video_path, "workdir": workdir, "title": safe_title})
            else:
                prog_dl.start_task(tid)
                prog_dl.update(tid, description=f"[bold blue][ID:{vid}] 下载: {safe_title}[/bold blue]", ui_state="active", pct_color="bright_blue")
                
                # Download
                video_path = os.path.join(workdir, safe_title + ".mp4")
                cmd = list(VDOWN_CMD) + [url, "--output", video_path]
                if args.cookies: cmd.extend(["--cookies", args.cookies])
                
                success = run_cmd_with_progress(cmd, prog_dl, tid, "Download", workdir, safe_title)
                if success:
                    # Double check if renamed by downloader
                    actual_vids = [f for f in glob.glob(os.path.join(workdir, "*")) if os.path.splitext(f)[1].lower() in ['.mp4', '.mkv', '.webm', '.ts', '.mov', '.avi'] and not f.endswith('.part') and '_hardsub' not in f.lower()]
                    if actual_vids: video_path = max(actual_vids, key=os.path.getmtime)
                    prog_dl.update(tid, description=f"[bold green][ID:{vid}] 下载: {safe_title}[/bold green]", ui_state="completed", pct_color="green", completed=100.0)
                    transcribe_queue.put({"uid": item['uid'], "video_path": video_path, "workdir": workdir, "title": safe_title})
                else:
                    prog_dl.update(tid, description=f"[bold red][ID:{vid}] 下载: {safe_title} (失败)[/bold red]", ui_state="failed", pct_color="bright_red")
            
            download_queue.task_done()
        except queue.Empty:
            break

def transcriber_worker(transcribe_queue, translate_queue, args, state):
    while not (state['download_done'] and transcribe_queue.empty()):
        if global_abort: break
        global_pause.wait()
        try:
            item = transcribe_queue.get(timeout=1)
            video_path = item["video_path"]
            workdir = item["workdir"]
            title = item["title"]
            base = os.path.splitext(os.path.basename(video_path))[0]
            
            vid = get_video_id(item['uid'])
            tid = tasks_tr.get(item['uid'])
            
            expected_srt = os.path.join(workdir, base + ".srt")
            expected_en = os.path.join(workdir, base + ".en.srt")
            
            src_srt = None
            if os.path.exists(expected_srt) and os.path.getsize(expected_srt) > 500: src_srt = expected_srt
            elif os.path.exists(expected_en) and os.path.getsize(expected_en) > 500: src_srt = expected_en
            
            if src_srt:
                log_event(workdir, "SKIP", f"Transcription exists: {os.path.basename(src_srt)}")
                item["src_srt"] = src_srt
                prog_tr.start_task(tid)
                prog_tr.update(tid, description=f"[grey50][ID:{vid}] 转录: {title} (跳过)[/grey50]", ui_state="skipped", pct_color="grey50", completed=100.0)
                item['uid'] = item['uid'] # already there
                translate_queue.put(item)
            else:
                dur = autosub.get_video_duration(video_path)
                dur_str = f"{int(dur)}s"
                
                prog_tr.start_task(tid)
                prog_tr.update(tid, description=f"[bold blue][ID:{vid}] 转录: {title} [{dur_str}][/bold blue]", ui_state="active", pct_color="bright_blue")
                
                cmd = list(TRANSCRIBER_CMD) + [video_path, "--model", args.model, "--output", workdir, "--no-gui"]
                success = run_cmd_with_progress(cmd, prog_tr, tid, "Transcribe", workdir, title)
                
                if success:
                    res = os.path.join(workdir, os.path.splitext(os.path.basename(video_path))[0] + ".srt")
                    if os.path.exists(res):
                        en_res = res.replace(".srt", ".en.srt")
                        if not os.path.exists(en_res): shutil.copy2(res, en_res)
                        item["src_srt"] = res
                        prog_tr.update(tid, description=f"[bold green][ID:{vid}] 转录: {title} [{dur_str}][/bold green]", ui_state="completed", pct_color="green", completed=100.0)
                        translate_queue.put(item)
                else:
                    prog_tr.update(tid, description=f"[bold red][ID:{vid}] 转录: {title} (失败)[/bold red]", ui_state="failed", pct_color="bright_red")
                    
            transcribe_queue.task_done()
        except queue.Empty:
            continue

def translator_worker(translate_queue, burn_queue, args, state):
    while not (state['transcribe_done'] and translate_queue.empty()):
        if global_abort: break
        global_pause.wait()
        try:
            item = translate_queue.get(timeout=1)
            src_srt = item["src_srt"]
            workdir = item["workdir"]
            title = item["title"]
            base = os.path.splitext(os.path.basename(item["video_path"]))[0]
            
            vid = get_video_id(item['uid'])
            tid = tasks_tl.get(item['uid'])
            
            expected_cn = os.path.join(workdir, base + ".cn.srt")
            expected_zh = os.path.join(workdir, base + ".zh.srt")
            
            zh_srt = None
            if os.path.exists(expected_cn) and os.path.getsize(expected_cn) > 500: zh_srt = expected_cn
            elif os.path.exists(expected_zh) and os.path.getsize(expected_zh) > 500: zh_srt = expected_zh
            
            if zh_srt:
                log_event(workdir, "SKIP", f"Translation exists: {os.path.basename(zh_srt)}")
                item["zh_srt"] = zh_srt
                prog_tl.start_task(tid)
                prog_tl.update(tid, description=f"[grey50][ID:{vid}] 翻译: {title} (跳过)[/grey50]", ui_state="skipped", pct_color="grey50", completed=100.0)
                burn_queue.put(item)
            else:
                prog_tl.start_task(tid)
                prog_tl.update(tid, description=f"[bold blue][ID:{vid}] 翻译: {title}[/bold blue]", ui_state="active", pct_color="bright_blue")
                
                cmd = [sys.executable, SMART_TRANSLATE_CMD[1], src_srt, "--style", args.style, "--model", args.llm_model, "--trans-mode", args.trans_mode]
                success = run_cmd_with_progress(cmd, prog_tl, tid, "Translate", workdir, title)
                
                if success:
                    zh_srt_path = expected_cn if os.path.exists(expected_cn) else expected_zh
                    if os.path.exists(zh_srt_path):
                        item["zh_srt"] = zh_srt_path
                        prog_tl.update(tid, description=f"[bold green][ID:{vid}] 翻译: {title}[/bold green]", ui_state="completed", pct_color="green", completed=100.0)
                        burn_queue.put(item)
                else:
                    prog_tl.update(tid, description=f"[bold red][ID:{vid}] 翻译: {title} (失败)[/bold red]", ui_state="failed", pct_color="bright_red")
            
            translate_queue.task_done()
        except queue.Empty:
            continue

def burner_worker(burn_queue, args, state):
    while not (state['translate_done'] and burn_queue.empty()):
        if global_abort: break
        global_pause.wait()
        try:
            item = burn_queue.get(timeout=1)
            src_srt = item["src_srt"]
            zh_srt = item["zh_srt"]
            video_path = item["video_path"]
            workdir = item["workdir"]
            title = item["title"]
            
            video_ext = os.path.splitext(video_path)[1]
            out_video = os.path.join(workdir, os.path.splitext(os.path.basename(video_path))[0] + "_hardsub" + video_ext)
            
            vid = get_video_id(item['uid'])
            
            tid_mg = tasks_mg.get(item['uid'])
            tid_bn = tasks_bn.get(item['uid'])
            
            if os.path.exists(out_video) and os.path.getsize(out_video) > 1024 * 1024:
                log_event(workdir, "SKIP", f"Hardsub exists: {os.path.basename(out_video)}")
                prog_mg.start_task(tid_mg)
                prog_mg.update(tid_mg, description=f"[grey50][ID:{vid}] 合并: {title} (跳过)[/grey50]", ui_state="skipped", pct_color="grey50", completed=100.0)
                prog_bn.start_task(tid_bn)
                prog_bn.update(tid_bn, description=f"[grey50][ID:{vid}] 烧录: {title} (跳过)[/grey50]", ui_state="skipped", pct_color="grey50", completed=100.0)
                burn_queue.task_done()
                continue
            
            # Merge & Format (.ass generation logically belongs here)
            prog_mg.start_task(tid_mg)
            
            bi_path = src_srt[:-7] + ".bi.srt" if src_srt.lower().endswith(".en.srt") else src_srt.replace(".srt", ".bi.srt")
            final_srt_candidate = bi_path if (os.path.exists(bi_path) and os.path.getsize(bi_path) > 100) else zh_srt
            ass_path_candidate = os.path.splitext(final_srt_candidate)[0] + ".ass"
            
            needs_bi = not (os.path.exists(bi_path) and os.path.getsize(bi_path) > 100)
            needs_ass = not os.path.exists(ass_path_candidate)
            
            if needs_bi or needs_ass:
                prog_mg.update(tid_mg, description=f"[bold blue][ID:{vid}] 合并: {title}[/bold blue]", ui_state="active", pct_color="bright_blue")
                
                if needs_bi:
                    cmd_merge = list(SUBTRANSLATOR_CMD) + ["merge", src_srt, "--translated-file", zh_srt]
                    run_cmd_with_progress(cmd_merge, prog_mg, tid_mg, "Merge", workdir, title)
                
                final_srt = bi_path if os.path.exists(bi_path) else zh_srt
                ass_path = os.path.splitext(final_srt)[0] + ".ass"
                
                if not os.path.exists(ass_path):
                    width, height = autosub.get_video_dimensions(video_path)
                    cmd_ass = list(SRT2ASS_CMD) + [final_srt, ass_path, "--layout", args.layout, "--main-lang", args.main_lang, "--cn-font", args.cn_font, "--en-font", args.en_font, "--cn-size", args.cn_size, "--en-size", args.en_size, "--cn-color", args.cn_color, "--en-color", args.en_color, "--width", str(width), "--height", str(height)]
                    if args.no_bg_box: cmd_ass.append("--no-bg-box")
                    subprocess.run(cmd_ass, check=False, capture_output=True)
                
                prog_mg.update(tid_mg, description=f"[bold green][ID:{vid}] 合并: {title}[/bold green]", ui_state="completed", pct_color="green", completed=100.0)
            else:
                log_event(workdir, "SKIP", f"Bilingual and ASS styles exist: {os.path.basename(bi_path)}")
                prog_mg.update(tid_mg, description=f"[grey50][ID:{vid}] 合并: {title} (跳过)[/grey50]", ui_state="skipped", pct_color="grey50", completed=100.0)
                final_srt = final_srt_candidate
                ass_path = ass_path_candidate
            
            # Burn
            prog_bn.start_task(tid_bn)
            prog_bn.update(tid_bn, description=f"[bold blue][ID:{vid}] 烧录: {title}[/bold blue]", ui_state="active", pct_color="bright_blue")
            
            # If the final _hardsub output already exists and we didn't skip it, generate a versioned filename
            def get_versioned_filename(filepath):
                if not os.path.exists(filepath): return filepath
                base, ext = os.path.splitext(filepath)
                match = re.search(r'_v(\d+)$', base)
                if match:
                    version = int(match.group(1)); base = base[:match.start()]
                else: version = 0
                while True:
                    version += 1
                    new_path = f"{base}_v{version}{ext}"
                    if not os.path.exists(new_path): return new_path

            safe_out_video = get_versioned_filename(out_video)
            
            cmd_burn = list(BURNSUB_CMD) + [video_path, ass_path, safe_out_video, "--headless"]
            success = run_cmd_with_progress(cmd_burn, prog_bn, tid_bn, "Burn", workdir, title)
            
            if success:
                prog_bn.update(tid_bn, description=f"[bold green][ID:{vid}] 烧录: {title}[/bold green]", ui_state="completed", pct_color="green", completed=100.0)
            else:
                prog_bn.update(tid_bn, description=f"[bold red][ID:{vid}] 烧录: {title} (失败)[/bold red]", ui_state="failed", pct_color="bright_red")
            
            burn_queue.task_done()
        except queue.Empty:
            continue

def run_batch(args):
    raw_urls = []
    if args.batch_urls:
        for u in args.batch_urls:
            if os.path.isfile(u):
                with open(u, 'r', encoding='utf-8') as f:
                    raw_urls.extend([line.strip() for line in f if line.strip() and not line.startswith("#")])
            else:
                raw_urls.append(u)
    
    unique_urls = []
    seen = set()
    for u in raw_urls:
        if u not in seen:
            unique_urls.append(u)
            seen.add(u)
    output_dir = args.output_dir or autosub.BASE_OUTPUT_DIR
    # Ensure no double wrapping and clean absolute pathways
    if not os.path.isabs(output_dir):
        output_dir = os.path.abspath(os.path.join(autosub.PROJECT_ROOT, output_dir))
    
    # Check if the output_dir is actually a playlist folder we want to be the root.
    
    download_queue = queue.Queue()
    transcribe_queue = queue.Queue()
    translate_queue = queue.Queue()
    burn_queue = queue.Queue()
    
    count_temp = 0
    for u in unique_urls:
        count_temp += 1
        tname = f"URL_{count_temp}"
        registry.append({"uid": tname, "title": tname, "is_url": True, "url": u})
        download_queue.put({'uid': tname, 'url': u, 'title': tname})
        
    if args.batch_dir and os.path.isdir(args.batch_dir):
        # 1. Check if the provided directory itself contains a video (Single Project Mode)
        vids = [f for f in glob.glob(os.path.join(args.batch_dir, "*")) if os.path.splitext(f)[1].lower() in ['.mp4', '.mkv', '.webm', '.ts', '.mov', '.avi'] and '_hardsub' not in f.lower()]
        if vids:
            video_path = max(vids, key=os.path.getmtime)
            registry.append({"uid": os.path.basename(args.batch_dir), "title": os.path.basename(args.batch_dir), "is_url": False, "is_local": True, "video_path": video_path})
            download_queue.put({'uid': os.path.basename(args.batch_dir), 'url': f"local://{video_path}", 'title': os.path.basename(args.batch_dir)})
        
        # 2. Traditional batch directory scan (Subdirectories)
        for entry in os.listdir(args.batch_dir):
            workdir = os.path.join(args.batch_dir, entry)
            if os.path.isdir(workdir):
                sub_vids = [f for f in glob.glob(os.path.join(workdir, "*")) if os.path.splitext(f)[1].lower() in ['.mp4', '.mkv', '.webm', '.ts', '.mov', '.avi'] and '_hardsub' not in f.lower()]
                if sub_vids:
                    video_path = max(sub_vids, key=os.path.getmtime)
                    registry.append({"uid": entry, "title": entry, "is_url": False, "is_local": True, "video_path": video_path})
                    download_queue.put({'uid': entry, 'url': f"local://{video_path}", 'title': entry})
                    
    state = {'download_done': False, 'transcribe_done': False, 'translate_done': False}
    workers = min(max(int(args.workers), 1), 10)
    translate_workers = max(1, int(args.max_api_calls) // 10)

    # Clean orphans before starting
    print("🧹 清理残留进程 (FFmpeg/Python)...")
    for proc in psutil.process_iter(['name', 'exe']):
        try:
            name = proc.info['name'].lower()
            if ('ffmpeg' in name or 'python' in name) and proc.pid != os.getpid():
                # Avoid killing ourselves or the editor/agent if possible
                cmd_line = " ".join(proc.cmdline()).lower()
                if 'autosub_batch.py' in cmd_line or 'ffmpeg' in name:
                    proc.kill()
        except: pass

    print(f"🚀 启动分布式动态批处理框架 (Workers={workers}, Translate Workers={translate_workers})")
    
    def key_listener(live_instance):
        global global_abort, global_ui_log, ui_scroll_offset
        import msvcrt
        awaiting_restart_id = False
        last_key_time = 0
        while not global_abort:
            if msvcrt.kbhit():
                t_now = time.time()
                k = msvcrt.getch()
                if t_now - last_key_time < 0.01:
                    continue
                last_key_time = t_now
                
                k_lower = k.lower()
                
                if awaiting_restart_id:
                    awaiting_restart_id = False
                    try:
                        char = k_lower.decode('utf-8')
                        if char == '\x1b': # ESC
                            global_ui_log = "⚠️ [gray]重启操作已取消。[/gray]"
                            continue
                        found_title = None
                        with registry_lock:
                            for title, vid in video_ids.items():
                                if str(vid) == char:
                                    found_title = title
                                    break
                        if found_title:
                            # 1. Kill existing progress if any
                            with registry_lock:
                                if found_title in active_processes:
                                    try:
                                        pid = active_processes[found_title]
                                        parent = psutil.Process(pid)
                                        for child in parent.children(recursive=True): child.kill()
                                        parent.kill()
                                    except: pass
                                    del active_processes[found_title]
                                if found_title in paused_videos:
                                    paused_videos.remove(found_title)
                            
                            # 2. Reset UI
                            for prog in [prog_dl, prog_tr, prog_tl, prog_mg, prog_bn]:
                                for task in prog.tasks:
                                    if getattr(task, "fields", {}).get('title') == found_title:
                                        vid_id = getattr(task, "fields", {}).get('vid')
                                        desc = task.description.split(']')[-1].strip().replace('(失败)', '').replace('[PAUSED]', '').strip()
                                        prog.update(task.id, ui_state="unstarted", pct_color="grey50", completed=0.0, description=f"[grey50][ID:{vid_id}] 等待重启: {desc}[/grey50]")
                            
                            global_ui_log = f"🚀 [bold green]已触发 '{found_title}' 的断点重启！正在重新加入队列...[/bold green]"
                            
                            # 3. Retrieve URL and queue
                            url_to_requeue = None
                            with registry_lock:
                                for item in registry:
                                    if item['title'] == found_title:
                                        url_to_requeue = item.get('url') if item.get('is_url') else f"local://{item.get('video_path')}"
                                        break
                                        
                            if url_to_requeue:
                                download_queue.put({'url': url_to_requeue, 'title': found_title})
                                import threading
                                t = threading.Thread(target=downloader_worker, args=(download_queue, transcribe_queue, args, output_dir), daemon=True)
                                t.start()
                        else:
                            global_ui_log = f"⚠️ [gray]重启已取消：未找到 ID 为 '{char}' 的任务。[/gray]"
                    except Exception as e:
                        global_ui_log = f"⚠️ [gray]重启操作异常取消 ({e})。[/gray]"
                    continue
                    
                if k_lower == b'p':
                    if global_pause.is_set(): 
                        global_pause.clear()
                        with registry_lock:
                            for title, pid in list(active_processes.items()):
                                if title not in paused_videos:
                                    suspend_process_tree(pid)
                                    paused_videos.add(title)
                        global_ui_log = "⏸️ [bold red]已强制挂起全局队列分配及所有进行中的任务...[/bold red]"
                    else: 
                        global_pause.set()
                        with registry_lock:
                            for title, pid in list(active_processes.items()):
                                if title in paused_videos:
                                    resume_process_tree(pid)
                                    paused_videos.remove(title)
                        global_ui_log = "▶️ [bold green]恢复全局队列分配及所有进行中的任务...[/bold green]"
                    # Update all UI tasks dynamically
                    for prog in [prog_dl, prog_tr, prog_tl, prog_mg, prog_bn]:
                        for task in prog.tasks:
                            title_val = getattr(task, "fields", {}).get('title')
                            if title_val:
                                ui_state = getattr(task, "fields", {}).get('ui_state')
                                base_desc = task.description.replace('[PAUSED] ', '')
                                new_desc = f"[PAUSED] {base_desc}" if (title_val in paused_videos and ui_state == 'active') else base_desc
                                prog.update(task.id, description=new_desc)
                elif k_lower == b'k':
                    global_abort = True
                    global_pause.set()
                    with registry_lock:
                        for title, pid in list(active_processes.items()):
                            try:
                                parent = psutil.Process(pid)
                                for child in parent.children(recursive=True): child.kill()
                                parent.kill()
                            except: pass
                    global_ui_log = "🛑 [bold red]紧急操作：已精准截杀本次衍生的所有 ffmpeg/python 子进程，并停止流水线！[/bold red]"
                elif k_lower == b'r':
                    awaiting_restart_id = True
                    global_ui_log = "🔄 [bold cyan]请按下你想重启的任务 ID 字符 (0-9, a-z)，或按 ESC 取消...[/bold cyan]"
                elif k_lower == b'q':
                    global_abort = True
                    global_pause.set()
                    global_ui_log = "🛑 [bold red]正在退出系统...[/bold red]"
                elif k == b'H' or k == b'w' or k_lower == b'w': # Scroll Up
                    ui_scroll_offset = max(0, ui_scroll_offset - 1)
                elif k == b'P' or k == b's' or k_lower == b's': # Scroll Down
                    if len(tasks_dl) > 15:
                        ui_scroll_offset = min(len(tasks_dl) - 15, ui_scroll_offset + 1)
                else:
                    try:
                        # Character filtering: Ignore control characters and known scroll sequences
                        if k[0] < 32 or k[0] > 126: continue 
                        
                        char = k_lower.decode('utf-8')
                        found_title = None
                        with registry_lock:
                            for title, vid in video_ids.items():
                                if str(vid) == char:
                                    found_title = title
                                    break
                        if found_title:
                            if found_title in paused_videos:
                                paused_videos.remove(found_title)
                                if found_title in active_processes: resume_process_tree(active_processes[found_title])
                                global_ui_log = f"▶️ [cyan]已恢复 '{found_title}' 的并发子进程。[/cyan]"
                            else:
                                paused_videos.add(found_title)
                                if found_title in active_processes: suspend_process_tree(active_processes[found_title])
                                global_ui_log = f"⏸️ [yellow]已原生冻结 '{found_title}' 的并发子进程！[/yellow]"
                            
                            for prog in [prog_dl, prog_tr, prog_tl, prog_mg, prog_bn]:
                                for task in prog.tasks:
                                    if getattr(task, "fields", {}).get('title') == found_title:
                                        ui_state = getattr(task, "fields", {}).get('ui_state')
                                        base_desc = task.description.replace('[PAUSED] ', '')
                                        new_desc = f"[PAUSED] {base_desc}" if (found_title in paused_videos and ui_state == 'active') else base_desc
                                        prog.update(task.id, description=new_desc)
                    except: pass
            time.sleep(0.1)

    # Clear terminal to prevent initialization artifacts from showing duplicate headers
    time.sleep(0.5)
    os.system("cls" if os.name == "nt" else "clear")

    # Initialize all tasks and stages globally for stable UI
    initialize_all_tasks()

    # --- GDrive Sync Hook ---
    if getattr(args, 'sync_gdrive', None):
        with open(os.devnull, 'w') as fnull:
            old_stdout = sys.stdout
            sys.stdout = fnull # Mute trigger_sync prints if any
            try:
                autosub.trigger_sync(output_dir, args.sync_gdrive)
            finally:
                sys.stdout = old_stdout

    # Start all progress instances to initialize their internal clocks for ETA calculation
    for p in [prog_dl, prog_tr, prog_tl, prog_mg, prog_bn]:
        p.start()
        
    try:
        with Live(DynamicPipelineGroup(), refresh_per_second=10, screen=True) as live:
            threading.Thread(target=key_listener, args=(live,), daemon=True).start()
        
            dl_threads = []
            if not download_queue.empty():
                for _ in range(workers):
                    t = threading.Thread(target=downloader_worker, args=(download_queue, transcribe_queue, args, output_dir))
                    t.start()
                    dl_threads.append(t)
                    
            tr_threads = []
            for _ in range(workers):
                t = threading.Thread(target=transcriber_worker, args=(transcribe_queue, translate_queue, args, state))
                t.start()
                tr_threads.append(t)
                
            tl_threads = []
            for _ in range(translate_workers):
                t = threading.Thread(target=translator_worker, args=(translate_queue, burn_queue, args, state))
                t.start()
                tl_threads.append(t)
                
            bn_threads = []
            for _ in range(workers):
                t = threading.Thread(target=burner_worker, args=(burn_queue, args, state))
                t.start()
                bn_threads.append(t)

            for t in dl_threads: t.join()
            state['download_done'] = True
            
            for t in tr_threads: t.join()
            state['transcribe_done'] = True
            
            for t in tl_threads: t.join()
            state['translate_done'] = True
            
            for t in bn_threads: t.join()
    finally:
        for p in [prog_dl, prog_tr, prog_tl, prog_mg, prog_bn]:
            p.stop()

    if global_abort:
        print("\n⚠️ 批量处理已被强制终止！已产出的字幕或文件将予以保留，发生中断的压制/下载在下次启动时需重新开始。")
    else:
        print("\n🎉 批量处理全部完成！")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="AutoSub 异步动态批处理框架")
    parser.add_argument("--batch-urls", nargs="+", help="YouTube URLs or path to a file containing URLs")
    parser.add_argument("--batch-dir", help="Directory containing local project folders for reprocessing")
    parser.add_argument("--output-dir", help="Output directory for all projects")
    parser.add_argument("--cookies", help="Path to cookies.txt")
    parser.add_argument("--workers", default=4, help="Number of concurrent download/transcribe/burn workers")
    parser.add_argument("--max-api-calls", default=20, help="Max total API calls (governs translate workers)")
    parser.add_argument("--model", default="large-v2", help="Whisper model for transcription")
    parser.add_argument("--llm-model", default="gemini-3-flash-preview", help="LLM model for translation")
    parser.add_argument("--style", default="casual", help="Translation style")
    parser.add_argument("--trans-mode", default="auto", help="Translation mode (auto/video/text)")
    parser.add_argument("--layout", default="bilingual", help="Subtitle layout")
    parser.add_argument("--main-lang", default="cn", help="Main language")
    parser.add_argument("--cn-font", default="STKaiti", help="Chinese font")
    parser.add_argument("--en-font", default="Calibri", help="English font")
    parser.add_argument("--cn-size", default="60", help="Chinese font size")
    parser.add_argument("--en-size", default="36", help="English font size")
    parser.add_argument("--cn-color", default="Gold", help="Chinese font color")
    parser.add_argument("--en-color", default="White", help="English font color")
    parser.add_argument("--no-bg-box", action="store_true", help="Disable background box for subtitles")
    parser.add_argument("--sync-gdrive", help="Google Drive Folder ID for automatic synchronization")
    
    args = parser.parse_args()
    
    if not args.batch_urls and not args.batch_dir:
        parser.print_help()
        sys.exit(1)
        
    run_batch(args)
