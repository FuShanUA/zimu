# Environment variable search paths (DO NOT CHANGE)
PYTHONPATH=Library/Tools/common:Library/Tools/autosub:Library/Tools/transcriber:Library/Tools/vdown:Library/Tools/hardsubber

# --- LLM Provider API Keys (Fill in your own) ---
# Gemini API Key (standard developer endpoint)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Vertex AI Configuration (optional, if using Vertex endpoints)
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/adc_credentials.json

# Other supported providers (optional)
ZHIPUAI_API_KEY=YOUR_ZHIPUAI_API_KEY_HERE
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY_HERE
MOONSHOT_API_KEY=YOUR_MOONSHOT_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Default model configuration
GOOGLE_GENAI_MODEL=gemini-3.5-flash
